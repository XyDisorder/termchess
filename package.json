{
  "name": "termchess",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm run --parallel dev:server dev:cli",
    "dev:server": "pnpm --filter @termchess/server dev",
    "dev:cli": "pnpm --filter ./apps/cli dev",
    "build": "pnpm --filter @termchess/protocol build && pnpm --filter @termchess/core build && pnpm --filter @termchess/server build && pnpm --filter ./apps/cli build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "cli": "pnpm --filter ./apps/cli start",
    "server": "pnpm --filter @termchess/server start"
  }
}
