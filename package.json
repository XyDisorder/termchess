{
  "name": "termchess",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm run --parallel dev:server dev:cli",
    "dev:server": "pnpm --filter @termchess/server dev",
    "dev:cli": "pnpm --filter @termchess/cli dev",
    "build": "pnpm -r --filter=./packages/* build && pnpm -r --filter=./apps/* build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean"
  }
}
