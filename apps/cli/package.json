{
  "name": "@termchess/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "termchess": "./dist/bin.js"
  },
  "scripts": {
    "dev": "tsx watch src/bin.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/bin.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/websocket": "^8.3.1",
    "@termchess/core": "workspace:*",
    "@termchess/protocol": "workspace:*",
    "fastify": "^4.26.2",
    "ink": "^4.4.1",
    "ink-spinner": "^5.0.0",
    "localtunnel": "^2.0.2",
    "react": "^18.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/localtunnel": "^2.0.4",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.52",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
