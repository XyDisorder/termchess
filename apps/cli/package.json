{
  "name": "termchess",
  "version": "0.1.0",
  "description": "Chess in your terminal — solo, vs engine, or multiplayer over the internet",
  "type": "module",
  "bin": {
    "termchess": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/bin.ts",
    "build": "pnpm typecheck && tsup",
    "start": "node dist/bin.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@fastify/websocket": "^8.3.1",
    "chess.js": "^1.0.0-beta.8",
    "fastify": "^4.26.2",
    "ink": "^4.4.1",
    "ink-spinner": "^5.0.0",
    "localtunnel": "^2.0.2",
    "nanoid": "^5.0.4",
    "react": "^18.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@termchess/core": "workspace:*",
    "@termchess/protocol": "workspace:*",
    "@types/localtunnel": "^2.0.4",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.52",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "chess",
    "terminal",
    "cli",
    "multiplayer",
    "ink"
  ],
  "license": "MIT"
}
